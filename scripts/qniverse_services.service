[Unit]
Description=Qniverse Services
After=network.target

[Service]
User=qniverse
Group=qacc
WorkingDirectory=/opt/qniverse-services

Environment="PATH=/opt/qniverse-services/venv/bin"
Environment="PACKAGE_BASE_DIR=/opt/qniverse-services/packages"

ExecStart=/opt/qniverse-services/venv/bin/gunicorn src.main:app \
    -k uvicorn.workers.UvicornWorker \
    --bind 0.0.0.0:8000 \
    --workers 1 \
    --timeout 120

Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
