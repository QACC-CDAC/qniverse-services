# API Configuration
API_V1_PREFIX=/api/v1
PROJECT_NAME=Transpilation API
VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production


# Package Installation Settings
PACKAGE_BASE_DIR=/home/qacc/qns-custom-packages
MAX_PACKAGES_PER_REQUEST=20
PACKAGE_INSTALL_TIMEOUT=300
PACKAGE_CLEANUP_AGE_HOURS=24


# Server Configuration
HOST=0.0.0.0
PORT=8000
WORKERS=4

# Security
SECRET_KEY=your-super-secret-key-change-in-production-min-32-characters
API_KEY_HEADER=X-API-Key
API_KEYS=prod-key-1,prod-key-2

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=10
REDIS_SOCKET_TIMEOUT=5

# Database (Optional - for storing history)
DATABASE_URL=postgresql://user:pass@localhost:5432/transpilation
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=40

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/transpilation_api.log
LOG_MAX_SIZE=500MB
LOG_BACKUP_COUNT=10

# CORS Configuration
ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
ALLOWED_HEADERS=*

# Transpilation Limits
MAX_CODE_LENGTH=50000
MAX_TIMEOUT_SECONDS=30
ENABLE_CACHE=true
CACHE_TTL_SECONDS=3600

# Monitoring
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
SENTRY_DSN=your-sentry-dsn-url

# Feature Flags
ENABLE_ASYNC_TRANSPILATION=false
ENABLE_CODE_VALIDATION=true
ENABLE_PERFORMANCE_METRICS=true